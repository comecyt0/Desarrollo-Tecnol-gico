/apps/api/app/Http/Controllers/Auth/    @comecyt0
/apps/api/config/cors.php               @comecyt0
/apps/api/config/jwt.php                @comecyt0
/apps/api/.env.example                  @comecyt0
/apps/api/deploy.sh                     @comecyt0
/apps/web/sentry.*.config.ts            @comecyt0
/apps/web/next.config.ts                @comecyt0
/.github/                               @comecyt0
/docs/security/                         @comecyt0

# ── Documentación ────────────────────────────────────────────────────
/docs/                                  @comecyt0
/README.md                              @comecyt0
/CLAUDE.md                              @comecyt0

