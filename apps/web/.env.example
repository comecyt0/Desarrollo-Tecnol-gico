# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# === INSTITUCIÓN (personalización sin tocar código) ===
# Estas variables las consume `lib/institution.ts` y propagan a todo el frontend.
# Setea las que necesites; las que dejes vacías toman valores default (COMECYT).
NEXT_PUBLIC_INSTITUTION_NAME=COMECYT
NEXT_PUBLIC_INSTITUTION_FULL_NAME="Consejo Mexiquense de Ciencia y Tecnología"
NEXT_PUBLIC_INSTITUTION_TAGLINE="Plataforma Institucional COMECYT"
NEXT_PUBLIC_INSTITUTION_SYSTEM_TAGLINE="Gestión De Proyectos de Desarrollo Tecnológico y Vinculación"
NEXT_PUBLIC_INSTITUTION_STATE="Estado de México"
NEXT_PUBLIC_INSTITUTION_EMAIL=administracion@comecyt.gob.mx
NEXT_PUBLIC_INSTITUTION_EMAIL_HINT=usuario@institucion.edu.mx
NEXT_PUBLIC_INSTITUTION_SECURITY_BADGE="Acceso Institucional Cifrado 256-bit"
NEXT_PUBLIC_INSTITUTION_LOCALE=es-MX
NEXT_PUBLIC_INSTITUTION_CURRENCY=MXN

# Logo institucional secundario (Gobierno Estado de México)
# Si se omite, usa /logo-edomex.svg (placeholder).
# Para ocultar el branding dual, usar el valor literal 'none'.
NEXT_PUBLIC_EDOMEX_LOGO_URL=/logo-edomex.svg

# === WebSockets (Laravel Reverb) ===
# Si se dejan vacíos, las notificaciones caen al polling cada 60s
# Deben coincidir con REVERB_* del backend (apps/api/.env)
NEXT_PUBLIC_REVERB_APP_KEY=local-key-change-in-prod
NEXT_PUBLIC_REVERB_HOST=127.0.0.1
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# === ERROR TRACKING (Sentry) ===
# Leave empty to disable — system works normally without it
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
