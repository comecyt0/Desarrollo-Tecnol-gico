APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

# === REVERB (WebSockets para notificaciones en tiempo real) ===
# En dev: ejecutar `php artisan reverb:start` en otra terminal
# En prod: usar Supervisor (ver resources/deploy/) o systemd para mantenerlo vivo
REVERB_APP_ID=comecyt
REVERB_APP_KEY=local-key-change-in-prod
REVERB_APP_SECRET=local-secret-change-in-prod
REVERB_HOST="127.0.0.1"
REVERB_PORT=8080
REVERB_SCHEME=http
# Frontend (Next.js) usa estas dos para conectar Echo:
NEXT_PUBLIC_REVERB_APP_KEY="${REVERB_APP_KEY}"
NEXT_PUBLIC_REVERB_HOST="${REVERB_HOST}"
NEXT_PUBLIC_REVERB_PORT="${REVERB_PORT}"
NEXT_PUBLIC_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email Configuration
# For development: use 'log' to send to logs, or 'smtp' with Mailpit on localhost:2525
# For production: use 'smtp' with real SMTP credentials
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@comecyt.gob.mx"
MAIL_FROM_NAME="COMECYT"

# Optional: Real SMTP for production
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.tu-proveedor.mx
# MAIL_PORT=587
# MAIL_USERNAME=tu-email@tu-dominio.mx
# MAIL_PASSWORD=tu-contraseña

# === LOGGING (todo a archivo local) ===
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=30
LOG_SECURITY_LEVEL=warning
LOG_SECURITY_DAYS=90

# Opcional: Sentry self-hosted (Docker) o SaaS — dejar vacío para 100% local
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_VERSION=

# === FRONTEND URL (para CTAs en emails de notificaciones) ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: NEXT_PUBLIC_APP_URL=https://dominio.edomex.gob.mx

# === TSA (Time Stamping Authority — sello de tiempo NOM-151) ===
# Dejar vacío para usar sólo sello local (SHA-256 + cadena de evidencia interna).
# Cuando el área de TIC del Estado entregue las credenciales del TSA acreditado:
TSA_URL=
TSA_USERNAME=
TSA_PASSWORD=
TSA_HASH_ALGORITHM=sha256

# === WEB PUSH (notificaciones nativas del navegador) ===
# Generar con: php artisan tinker → Minishlink\WebPush\VAPID::createVapidKeys()
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@comecyt.gob.mx

# === CORS — orígenes permitidos en producción (CSV) ===
# Localhost ya está incluido por defecto en config/cors.php
CORS_ALLOWED_ORIGINS=https://dominio.edomex.gob.mx

# === COOKIE DEL JWT (producción) ===
# Cuando frontend y backend comparten dominio (Nginx/IIS reverse-proxy):
COOKIE_DOMAIN=.dominio.edomex.gob.mx
COOKIE_SECURE=true
COOKIE_SAME_SITE=Strict

# === SEGURIDAD — Rate Limiting y Lockout ===
# Límite global de peticiones por IP por minuto (todas las rutas /api/*).
# 300 es razonable para una SPA admin que dispara ~15-20 requests por página.
# Si tienes muchos admins detrás del mismo NAT corporativo, sube a 600+.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60
# Intentos de login antes de bloquear por IP (ventana de AUTH_LOGIN_RATE_WINDOW segundos)
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW=60
# Intentos fallidos por email antes de bloquear la cuenta temporalmente
AUTH_ACCOUNT_LOCKOUT=10
AUTH_LOCKOUT_MINUTES=15

# === TRUSTED PROXIES — Reverse proxy / load balancer ===
# Comma-separated IPs. Set to * only if behind a cloud LB that sanitizes X-Forwarded-For.
# Default: 127.0.0.1 (Nginx en el mismo servidor reverse-proxyeando a Laravel)
TRUSTED_PROXIES=127.0.0.1

# === API GATEWAY — Protección contra DDoS ===
# Número de IPs distintas en 60s que activa el modo lockdown
API_GATEWAY_MAX_IPS=1000
# Minutos que dura el lockdown del gateway
API_GATEWAY_LOCKDOWN_MINUTES=5

VITE_APP_NAME="${APP_NAME}"
