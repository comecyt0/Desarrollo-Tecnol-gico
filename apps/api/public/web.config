<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMECYT — IIS reverse proxy + PHP FastCGI (despliegue Windows)
  Un solo sitio enrutando:
    *.php           -> PHP 8.4 via FastCGI (php-cgi.exe)
    archivos reales -> servidos estaticamente por IIS (incluye /storage)
    /api /up        -> Laravel front controller (index.php)
    /app /apps      -> Laravel Reverb (WebSocket) en 127.0.0.1:8080  (ARR)
    resto           -> Next.js standalone en 127.0.0.1:3000          (ARR)
-->
<configuration>
  <system.webServer>

    <handlers>
      <add name="PHP-FastCGI" path="*.php" verb="*" modules="FastCgiModule"
           scriptProcessor="C:\php\php-cgi.exe" resourceType="Either" requireAccess="Script" />
    </handlers>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
      </files>
    </defaultDocument>

    <!-- El modulo WebSocket de IIS debe estar ACTIVO para que ARR complete el handshake 101 hacia Reverb -->
    <webSocket enabled="true" />

    <httpErrors existingResponse="PassThrough" />

    <rewrite>
      <rules>

        <!-- 0a) localhost -> redirige al dominio real con HTTPS -->
        <rule name="LocalhostRedirect" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^localhost$" />
          </conditions>
          <action type="Redirect" url="https://comecyt-sistemas.edomex.gob.mx/{R:1}" redirectType="Found" />
        </rule>

        <!-- 0b) Forzar HTTPS (excepto el challenge HTTP-01 de Let's Encrypt) -->
        <rule name="HttpsRedirect" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
            <add input="{REQUEST_URI}" pattern="^/\.well-known/acme-challenge/" negate="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 1) Reverb WebSocket (protocolo Pusher: /app/{key}) -> Reverb 8080 -->
        <rule name="ReverbWS" stopProcessing="true">
          <match url="^(app|apps)(/.*)?$" />
          <action type="Rewrite" url="http://127.0.0.1:8080/{R:0}" />
        </rule>

        <!-- 2) Archivos fisicos existentes (assets, /storage/*) -> servir directo -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url="^.*$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- 3) Rutas propias de Laravel -> front controller index.php (FastCGI) -->
        <rule name="LaravelApi" stopProcessing="true">
          <match url="^(api|up|sanctum|broadcasting)(/.*)?$" />
          <action type="Rewrite" url="index.php" />
        </rule>

        <!-- 4) Todo lo demas (UI) -> Next.js 3000 -->
        <rule name="NextJsProxy" stopProcessing="true">
          <match url="^(.*)$" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" appendQueryString="true" />
        </rule>

      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <!-- Subir el tope de IIS (default ~28.6 MB) para permitir PDFs hasta 50 MB (coincide con php.ini) -->
        <requestLimits maxAllowedContentLength="52428800" />
        <hiddenSegments>
          <add segment=".env" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
