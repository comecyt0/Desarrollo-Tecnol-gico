# Auto-detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for shell scripts (no CRLF en Windows)
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# PHP, JS, TS, JSON, YAML — always LF
*.php text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Force CRLF for Windows batch files (cuando corresponda)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.woff binary
*.woff2 binary

# Excluir del export/archive (no se incluyen al hacer git archive)
.github/ export-ignore
.gitattributes export-ignore
.gitignore export-ignore
.husky/ export-ignore
docs/ export-ignore
tests/ export-ignore
phpunit.xml export-ignore
.editorconfig export-ignore

# Linguist — categorizar correctamente lenguajes en GitHub
*.blade.php linguist-language=PHP
docs/* linguist-documentation
LICENSE linguist-documentation
