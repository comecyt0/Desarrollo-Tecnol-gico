# ============================================================
# COMECYT SYSTEM — Template de Variables de Entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA commitear el .env real al repositorio
# ============================================================

# === APLICACIÓN ===
APP_ENV=local
APP_DEBUG=true

# === BASE DE DATOS (PostgreSQL) ===
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=comecyt_dev
DB_USERNAME=comecyt
DB_PASSWORD=

# === API ===
API_URL=http://localhost:8000
API_PREFIX=api

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# === JWT / AUTH ===
JWT_SECRET=
JWT_TTL=1440

# === CORREO (dev: Mailpit) ===
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@comecyt.gob.mx
MAIL_FROM_NAME="COMECYT Sistema"

# === SEGURIDAD ===
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60
API_GATEWAY_MAX_IPS=1000
API_GATEWAY_LOCKDOWN_MINUTES=5
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30
